FROM node:20-slim AS build

WORKDIR /app

# Workspace metadata for install caching
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./

# Copy only package manifests we need for dependency graph resolution
COPY packages/api/package.json packages/api/package.json
COPY packages/actors/package.json packages/actors/package.json
COPY packages/bus/package.json packages/bus/package.json
COPY packages/characters/package.json packages/characters/package.json
COPY packages/db/package.json packages/db/package.json
COPY packages/generator/package.json packages/generator/package.json
COPY packages/llm/package.json packages/llm/package.json
COPY packages/projections/package.json packages/projections/package.json
COPY packages/retrieval/package.json packages/retrieval/package.json
COPY packages/schemas/package.json packages/schemas/package.json
COPY packages/services/package.json packages/services/package.json
COPY packages/ui/package.json packages/ui/package.json
COPY packages/utils/package.json packages/utils/package.json
COPY packages/web/package.json packages/web/package.json
COPY packages/workers/package.json packages/workers/package.json

RUN corepack enable && CI=true pnpm -r install --frozen-lockfile

# Copy the rest of the repo and build the API and its workspace dependencies
COPY . .

# Some environments (e.g. CI) may not include a data/ directory
RUN mkdir -p /app/data

# Ensure workspace links exist after source copy (COPY can introduce new workspaces)
RUN CI=true pnpm -r install --frozen-lockfile --prefer-offline

# Build only what the API needs (the ... suffix includes dependencies)
RUN node scripts/generate-sensory-templates.mjs
RUN pnpm turbo run build --filter=@minimal-rpg/api...


FROM node:20-slim AS runtime

WORKDIR /app
ENV NODE_ENV=production

# Copy runtime deps and built outputs
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/package.json ./package.json
COPY --from=build /app/pnpm-workspace.yaml ./pnpm-workspace.yaml
COPY --from=build /app/packages ./packages

# The API loads JSON data from the repo-root data/ directory by default
COPY --from=build /app/data ./data

EXPOSE 3001

CMD ["node", "packages/api/dist/server.js"]
