{
  "name": "minimal-rpg",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm clean:dist && turbo build",
    "check": "turbo lint && turbo typecheck && pnpm lint:md",
    "clean": "turbo clean",
    "clean:dist": "find packages -name 'dist' -type d -exec rm -rf {} + 2>/dev/null || true",
    "precore": "pnpm install --frozen-lockfile",
    "core": "node scripts/core.mjs",
    "core:quit": "node scripts/core-quit.mjs",
    "dev": "turbo dev",
    "docker:down": "docker compose down",
    "docker:up": "docker compose up --build",
    "docker:up:detached": "docker compose up --build -d",
    "lint": "turbo lint",
    "lint:md": "markdownlint \"**/*.md\" --ignore node_modules --ignore dist --ignore packages/web/dist --ignore .turbo",
    "lint:staged": "lint-staged",
    "prepare": "husky",
    "test": "turbo test",
    "test:trait": "node scripts/test-trait.mjs",
    "typecheck": "turbo typecheck"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,scss,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "fast-json-patch": "3.1.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@eslint/js": "^9.39.1",
    "@secretlint/secretlint-rule-preset-recommend": "^11.2.5",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "markdownlint-cli": "^0.45.0",
    "prettier": "^3.6.2",
    "prettier-plugin-packagejson": "^2.5.19",
    "secretlint": "^11.2.5",
    "tsup": "^8.5.1",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.0.16"
  },
  "packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a"
}
