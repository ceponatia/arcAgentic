{
  "name": "arcagentic",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "db:migrate": "pnpm --filter @arcagentic/db run db:migrate",
    "dev": "turbo run dev --filter=@arcagentic/api --filter=@arcagentic/web",
    "infra:down": "node infra.mjs down",
    "infra:up": "node infra.mjs up",
    "lint": "pnpm --filter './packages/*' --filter './apps/*' -r --parallel --if-present run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@eslint/js": "^9.39.1",
    "@types/node": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "drizzle-kit": "catalog:",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^3.0.1",
    "fast-json-patch": "catalog:",
    "glob": "^13.0.0",
    "pg": "catalog:",
    "rimraf": "catalog:",
    "tsx": "catalog:",
    "turbo": "^2.8.3",
    "typescript": "catalog:",
    "typescript-eslint": "^8.46.4",
    "zod": "catalog:"
  },
  "pnpm": {
    "patchedDependencies": {
      "openai@6.17.0": "patches/openai@6.17.0.patch"
    },
    "overrides": {
      "flatted": ">=3.4.0",
      "lodash": "4.17.23"
    }
  },
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264"
}
