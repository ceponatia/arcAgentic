{
  "name": "arcagentic",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "db:migrate": "pnpm --filter @arcagentic/db run db:migrate",
    "dev": "turbo run dev --filter=@arcagentic/api --filter=@arcagentic/web",
    "infra:down": "node infra.mjs down",
    "infra:up": "node infra.mjs up",
    "lint": "pnpm --filter './packages/*' --filter './apps/*' -r --parallel --if-present run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "fast-json-patch": "3.1.1",
