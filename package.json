{
  "name": "minimal-rpg",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:watch": "turbo run build --watch",
    "dev": "turbo run dev",
    "dev:kill": "node scripts/kill-ports.mjs 3001 5173",
    "lint": "turbo run lint",
    "refs:check": "node scripts/sync-ts-references.mjs && git diff --exit-code",
    "refs:sync": "node scripts/sync-ts-references.mjs",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,scss,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "fast-json-patch": "3.1.1",
    "pg": "^8.16.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@eslint/js": "^9.39.1",
    "@secretlint/secretlint-rule-preset-recommend": "^11.2.5",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.16.0",
    "@vitest/coverage-v8": "4.0.16",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "markdownlint-cli": "^0.45.0",
    "prettier": "^3.6.2",
    "prettier-plugin-packagejson": "^2.5.19",
    "rimraf": "^6.1.2",
    "secretlint": "^11.2.5",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.0.16"
  },
  "packageManager": "pnpm@10.27.0+sha512.72d699da16b1179c14ba9e64dc71c9a40988cbdc65c264cb0e489db7de917f20dcf4d64d8723625f2969ba52d4b7e2a1170682d9ac2a5dcaeaab732b7e16f04a"
}
