{
  "name": "@minimal-rpg/actors",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "pnpm exec tsc -b",
    "clean": "rimraf dist node_modules/.cache/tsbuildinfo",
    "lint": "eslint src --ext .ts --cache --cache-location ../../.eslintcache",
    "test": "vitest run",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@minimal-rpg/bus": "workspace:*",
    "@minimal-rpg/schemas": "workspace:*",
    "@minimal-rpg/services": "workspace:*",
    "xstate": "^5.18.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "rimraf": "^6.1.2",
    "typescript": "^5.6.3",
    "vitest": "^1.6.0"
  }
}
