{
  "name": "@arcagentic/actors",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist node_modules/.cache/tsbuildinfo",
    "lint": "eslint src --cache --cache-location node_modules/.cache/eslint",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@arcagentic/bus": "workspace:*",
    "@arcagentic/llm": "workspace:*",
    "@arcagentic/schemas": "workspace:*",
    "@arcagentic/services": "workspace:*",
    "effect": "3.10.13",
    "xstate": "^5.18.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "rimraf": "^6.1.2",
    "typescript": "^5.6.3"
  }
}
