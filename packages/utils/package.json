{
  "name": "@minimal-rpg/utils",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm exec tsc -b",
    "clean": "rimraf dist node_modules/.cache/tsbuildinfo",
    "lint": "eslint src --ext .ts --cache --cache-location ../../.eslintcache",
    "typecheck": "pnpm exec tsc -b --noEmit"
  },
  "dependencies": {
    "@minimal-rpg/schemas": "workspace:*",
    "fast-json-patch": "^3.1.1"
  },
  "devDependencies": {
    "tsup": "^8.0.0"
  }
}
