{
  "name": "@arcagentic/utils",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist node_modules/.cache/tsbuildinfo -g 'src/**/*.js' 'src/**/*.d.ts' 'src/**/*.d.ts.map'",
    "lint": "eslint src --cache --cache-location node_modules/.cache/eslint",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@arcagentic/schemas": "workspace:*",
    "fast-json-patch": "^3.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1"
  }
}
