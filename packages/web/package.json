{
  "name": "@minimal-rpg/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "clean": "rimraf dist node_modules/.cache/tsbuildinfo",
    "dev": "vite",
    "lint": "eslint src --ext .ts,.tsx --cache --cache-location ../../.eslintcache",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "@minimal-rpg/db": "workspace:*",
    "@minimal-rpg/generator": "workspace:*",
    "@minimal-rpg/schemas": "workspace:*",
    "@minimal-rpg/ui": "workspace:*",
    "@minimal-rpg/utils": "workspace:*",
    "@preact/signals-react": "^3.6.1",
    "@supabase/supabase-js": "^2.57.4",
    "@xyflow/react": "^12.10.0",
    "lucide-react": "^0.561.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/typography": "^0.5.15",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.16",
    "autoprefixer": "^10.4.20",
    "jsdom": "^27.3.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "vite": "^7.2.2",
    "vitest": "^4.0.16"
  }
}
