{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,

    "rootDir": "src",
    "outDir": "dist",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "lib": ["dom", "dom.iterable", "es2023"],
    "jsx": "react-jsx",

    "tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo"
  },
  "include": ["src"],
  "exclude": ["dist", "**/*.test.ts", "**/*.test.tsx"],
  "references": [
    { "path": "../db" },
    { "path": "../generator" },
    { "path": "../schemas" },
    { "path": "../ui" },
    { "path": "../utils" }
  ]
}
