{
  "name": "@arcagentic/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist node_modules/.cache/tsbuildinfo",
    "lint": "eslint src --cache --cache-location node_modules/.cache/eslint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage.enabled=true",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@arcagentic/schemas": "workspace:*",
    "clsx": "^2.1.0",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^2.2.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "autoprefixer": "^10.4.20",
    "jsdom": "^27.3.0",
    "postcss": "^8.4.47",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rimraf": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "catalog:"
  }
}
