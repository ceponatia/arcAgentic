{
  "name": "@minimal-rpg/characters",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "pnpm exec tsc -b",
    "clean": "rimraf dist node_modules/.cache/tsbuildinfo",
    "lint": "eslint src --ext .ts --cache --cache-location ../../.eslintcache",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@minimal-rpg/retrieval": "workspace:*",
    "@minimal-rpg/schemas": "workspace:*",
    "@minimal-rpg/utils": "workspace:*",
    "fast-json-patch": "^3.1.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.16",
    "vitest": "^4.0.16"
  }
}
