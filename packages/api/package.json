{
  "name": "@minimal-rpg/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src --max-warnings=0",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@minimal-rpg/agents": "workspace:*",
    "@minimal-rpg/db": "workspace:*",
    "@minimal-rpg/governor": "workspace:*",
    "@minimal-rpg/retrieval": "workspace:*",
    "@minimal-rpg/schemas": "workspace:*",
    "@minimal-rpg/state-manager": "workspace:*",
    "@minimal-rpg/utils": "workspace:*",
    "dotenv": "^17.2.3",
    "hono": "^4.10.6",
    "jose": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
