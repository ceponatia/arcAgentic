{
  "name": "@arcagentic/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist node_modules/.cache/tsbuildinfo",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src --cache --cache-location node_modules/.cache/eslint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage.enabled=true",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.10",
    "@arcagentic/actors": "workspace:*",
    "@arcagentic/bus": "workspace:*",
    "@arcagentic/db": "workspace:*",
    "@arcagentic/generator": "workspace:*",
    "@arcagentic/logger": "workspace:*",
    "@arcagentic/llm": "workspace:*",
    "@arcagentic/narrator": "workspace:*",
    "@arcagentic/projections": "workspace:*",
    "@arcagentic/retrieval": "workspace:*",
    "@arcagentic/schemas": "workspace:*",
    "@arcagentic/services": "workspace:*",
    "@arcagentic/utils": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "effect": "catalog:",
    "hono": "^4.12.4",
    "ioredis": "catalog:",
    "jose": "^6.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "rimraf": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
