# API configuration
PORT=3001
DATABASE_URL=postgres://postgres:postgres@localhost:5432/minirpg

# OpenRouter (DeepSeek via OpenRouter is default)
OPENROUTER_API_KEY=REMOVED_SECRET
OPENROUTER_MODEL=deepseek/deepseek-chat

# Prompt / generation controls
CONTEXT_WINDOW=12
TEMPERATURE=0.7
TOP_P=0.9

# Debug modes
GOVERNOR_DEV_MODE=true
INTENT_DEBUG=true

# Turn handler mode: classic | tool-calling | hybrid
# - classic: Rule-based intent detection (default)
# - tool-calling: LLM decides when to call tools based on context
# - hybrid: Use tool-calling for complex inputs, classic for simple ones
TURN_HANDLER=classic

# Admin tools
ADMIN_DB_TOOLS=true
VITE_DB_TOOLS=true