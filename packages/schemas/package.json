{
  "name": "@minimal-rpg/schemas",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./character": {
      "import": "./dist/character.js",
      "types": "./dist/character.d.ts"
    },
    "./setting": {
      "import": "./dist/setting.js",
      "types": "./dist/setting.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm exec tsc -b",
    "clean": "rimraf dist node_modules/.cache/tsbuildinfo",
    "lint": "eslint src --ext .ts --cache --cache-location ../../.eslintcache",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "vitest": "^1.6.0"
  }
}
