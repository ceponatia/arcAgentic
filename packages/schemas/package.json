{
  "name": "@minimal-rpg/schemas",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./character": {
      "import": "./dist/character.js",
      "types": "./dist/character.d.ts"
    },
    "./setting": {
      "import": "./dist/setting.js",
      "types": "./dist/setting.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint src --max-warnings=0",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.0.0",
    "vitest": "^1.6.0"
  }
}
