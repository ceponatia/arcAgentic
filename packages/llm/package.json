{
  "name": "@minimal-rpg/llm",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "pnpm exec tsc -b",
    "clean": "rimraf dist node_modules/.cache/tsbuildinfo",
    "lint": "eslint src --ext .ts --cache --cache-location ../../.eslintcache",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@minimal-rpg/schemas": "workspace:*",
    "@minimal-rpg/utils": "workspace:*",
    "effect": "3.10.13",
    "openai": "^4.76.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "rimraf": "^6.1.2",
    "typescript": "^5.6.3"
  }
}
