{
  "name": "@minimal-rpg/retrieval",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "pnpm exec tsc -b",
    "clean": "rimraf dist node_modules/.cache/tsbuildinfo",
    "lint": "eslint src --ext .ts --cache --cache-location ../../.eslintcache",
    "test": "vitest run --passWithNoTests",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@minimal-rpg/db": "workspace:*",
    "@minimal-rpg/schemas": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^3.2.3"
  }
}
