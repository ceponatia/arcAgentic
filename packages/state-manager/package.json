{
  "name": "@minimal-rpg/state-manager",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "pnpm exec tsc -b",
    "clean": "rimraf dist node_modules/.cache/tsbuildinfo",
    "lint": "eslint src --ext .ts --cache --cache-location ../../.eslintcache",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --passWithNoTests --coverage",
    "test:watch": "vitest",
    "typecheck": "pnpm exec tsc -b --noEmit"
  },
  "dependencies": {
    "@minimal-rpg/schemas": "workspace:*",
    "fast-json-patch": "^3.1.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
