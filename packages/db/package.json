{
  "name": "@minimal-rpg/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./node": {
      "import": "./dist/node.js",
      "types": "./dist/node.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "pnpm exec tsc -b",
    "clean": "rimraf dist node_modules/.cache/tsbuildinfo",
    "db:migrate": "tsx src/migrations/migrate.ts",
    "db:seed": "tsx src/seed.ts",
    "db:seed:test-entities": "tsx src/seed.ts --test-entities --mode upsert",
    "lint": "eslint src --ext .ts --cache --cache-location ../../.eslintcache",
    "test": "vitest run",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@minimal-rpg/schemas": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "ioredis": "^5.4.1",
    "pg": "^8.13.1",
    "pgvector": "^0.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.24.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^1.6.0"
  }
}
