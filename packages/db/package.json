{
  "name": "@arcagentic/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./node": {
      "import": "./dist/node.js",
      "types": "./dist/node.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist node_modules/.cache/tsbuildinfo",
    "db:migrate": "tsx src/migrations/migrate.ts",
    "db:migrate:fresh": "SQL_DIR=sql-fresh tsx src/migrations/migrate.ts",
    "db:seed": "tsx src/seed.ts",
    "db:seed:test-entities": "tsx src/seed.ts --test-entities --mode upsert",
    "lint": "eslint src --cache --cache-location node_modules/.cache/eslint",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@arcagentic/schemas": "workspace:*",
    "@arcagentic/utils": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "ioredis": "^5.4.1",
    "pg": "^8.13.1",
    "pgvector": "^0.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
