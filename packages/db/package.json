{
  "name": "@arcagentic/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./node": {
      "import": "./dist/node.js",
      "types": "./dist/node.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist node_modules/.cache/tsbuildinfo",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrations/migrate.ts",
    "db:seed": "tsx src/seed.ts",
    "db:seed:test-entities": "tsx src/seed.ts --test-entities --mode upsert",
    "lint": "eslint src --cache --cache-location node_modules/.cache/eslint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage.enabled=true",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@arcagentic/schemas": "workspace:*",
    "@arcagentic/utils": "workspace:*",
    "drizzle-orm": "catalog:",
    "ioredis": "catalog:",
    "pg": "catalog:",
    "pgvector": "^0.2.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "dotenv": "catalog:",
    "drizzle-kit": "catalog:",
    "rimraf": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
