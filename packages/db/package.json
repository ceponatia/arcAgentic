{
  "name": "@minimal-rpg/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./node": {
      "types": "./src/node.ts",
      "default": "./dist/node.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json --outDir dist",
    "clean": "rimraf dist node_modules/.cache/tsbuildinfo",
    "db:migrate": "tsx src/migrate.ts",
    "db:seed": "tsx src/seed.ts",
    "db:seed:test-entities": "tsx src/seed.ts --test-entities --mode upsert",
    "lint": "eslint src --ext .ts --cache --cache-location ../../.eslintcache",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "pg": "^8.13.1",
    "pgvector": "^0.2.1"
  },
  "@types/node": "^24.10.1",
  "@types/pg": "^8.15.6",
  "tsx": "^4.20.6",
  "typescript": "^5.6.3",
  "vitest": "^1.6.0"
}
