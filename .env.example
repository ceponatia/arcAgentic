# Minimal RPG - environment example
# Copy this file to `.env` and adjust as needed.

# OpenRouter API key (required if using OpenRouter)
OPENROUTER_API_KEY=

# Optional OpenRouter model override
# OPENROUTER_MODEL=deepseek/deepseek-chat

# If port 5432 is already taken on your machine, set this to 5433 (or any free port).
PG_PORT=5433

# If ports are already taken on your machine, change these.
API_PORT=3001
WEB_PORT=5173

# Ollama local server base URL (default port is 11434)
OLLAMA_BASE_URL=http://localhost:11434

# Mistral Instruct 7B model name in Ollama
# Common options: `mistral:instruct` (explicit instruct), or `mistral:latest`
OLLAMA_MODEL=mistral:instruct

# API server port
PORT=3001
