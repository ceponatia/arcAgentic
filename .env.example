# Minimal RPG - environment example
# Copy this file to `.env` and adjust as needed.

# This monorepo uses a single repo-root `.env`.
# The API and DB tooling load it directly, and Vite is configured to load it via `envDir`.

# OpenRouter API key (required if using OpenRouter)
OPENROUTER_API_KEY=

# Define OpenRouter model
OPENROUTER_MODEL=

# OpenRouter provider sorting: price | throughput | latency
# Default (unset) uses OpenRouter's load balancing based on price + uptime
# See: https://openrouter.ai/docs/guides/routing/provider-selection
OPENROUTER_PROVIDER_SORT=latency

# Database (used by API + scripts). For Docker Compose, PG_PORT controls the local port.

# Select which database to target.
# - local: use DATABASE_URL_LOCAL (recommended for dev)
# - supabase: use DATABASE_URL_SUPABASE (or DATABASE_URL)
# - (unset): use DATABASE_URL
DB_TARGET=local

# Local Postgres (host machine)
DATABASE_URL_LOCAL=postgres://postgres:postgres@localhost:5432/minirpg

# Primary DB url.
# - For local dev, you can leave this blank when DB_TARGET=local.
# - For staging/prod (Fly), set DATABASE_URL via Fly secrets to your Supabase connection string.
DATABASE_URL=

# Optional explicit Supabase url (only needed if you want DB_TARGET=supabase locally)
# DATABASE_URL_SUPABASE=postgres://...sslmode=require

# If port 5432 is already taken on your machine, set this to 5433 (or any free port).
PG_PORT=5433

# If ports are already taken on your machine, change these.
API_PORT=3001
WEB_PORT=5173

# Ollama local server base URL (default port is 11434)
OLLAMA_BASE_URL=

# Set Ollama model name. Development was done using mistral:instruct-7b-v0.1
OLLAMA_MODEL=

# API server port
PORT=3001

# Auth (Supabase as identity provider)
# SUPABASE_PROJECT_URL=https://<ref>.supabase.co
# SUPABASE_JWT_ISSUER=https://<ref>.supabase.co/auth/v1
# Optional (only set if you configured/need audience validation)
# SUPABASE_JWT_AUDIENCE=authenticated

# For playtesting, require auth for all non-public routes
# AUTH_REQUIRED=true

# Invite-only playtest gating (email allowlist)
# INVITE_ONLY=true
# INVITE_EMAILS=tester1@example.com,tester2@example.com

# Admin privileges (comma-separated emails)
# ADMIN_EMAILS=you@example.com

# CORS allowlist (comma-separated origins)
# CORS_ORIGINS=https://ceponatia.github.io,http://localhost:5173

# Optional local admin password for dev-only admin actions
# LOCAL_ADMIN_PASSWORD=change-me

# Web (Vite) - Supabase Auth
# VITE_SUPABASE_URL=https://<ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=...
# VITE_API_BASE_URL=https://<your-fly-app>.fly.dev
