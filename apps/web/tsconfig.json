{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "src",
    "outDir": "dist",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "dom",
      "dom.iterable",
      "es2023"
    ],
    "jsx": "react-jsx",
    "types": [
      "vite/client"
    ],
    "tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo"
  },
  "include": [
    "src"
  ],
  "exclude": [
    "dist",
    "**/*.test.ts",
    "**/*.test.tsx"
  ],
  "references": [
    {
      "path": "../../packages/db"
    },
    {
      "path": "../../packages/generator"
    },
    {
      "path": "../../packages/schemas"
    },
    {
      "path": "../../packages/ui"
    },
    {
      "path": "../../packages/utils"
    }
  ]
}
