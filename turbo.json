{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "BASE_PATH",
    "VITE_API_BASE_URL",
    "VITE_API_MESSAGE_TIMEOUT_MS",
    "VITE_STRICT_MODE",
    "VITE_USE_TURNS_API",
    "VITE_GOVERNOR_DEV_MODE"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "node_modules/.cache/tsbuildinfo"]
    },

    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },

    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },

    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },

    "dev": {
      "cache": false,
      "persistent": true
    },

    "clean": {
      "dependsOn": ["^clean"],
      "cache": false
    }
  }
}
