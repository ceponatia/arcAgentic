{
  "folders": [
    {
      "name": "root",
      "path": ".",
      "root": true,
      "exclude": [
        "node_modules",
        "dist",
        "build",
        "coverage",
        "logs",
        "temp",
        "tmp",
        ".cache",
        ".next",
        ".nuxt",
        ".vercel",
        ".serverless",
        ".parcel-cache",
        ".eslintcache",
        ".prettiercache",
        "apps/web",
        "packages"
      ]
    },
    {
      "name": "actors",
      "path": "packages/actors"
    },
    {
      "name": "api",
      "path": "packages/api"
    },
    {
      "name": "bus",
      "path": "packages/bus"
    },
    {
      "name": "characters",
      "path": "packages/characters"
    },
    {
      "name": "db",
      "path": "packages/db"
    },
    {
      "name": "generator",
      "path": "packages/generator"
    },
    {
      "name": "llm",
      "path": "packages/llm"
    },
    {
      "name": "logger",
      "path": "packages/logger"
    },
    {
      "name": "narrator",
      "path": "packages/narrator"
    },
    {
      "name": "projections",
      "path": "packages/projections"
    },
    {
      "name": "retrieval",
      "path": "packages/retrieval"
    },
    {
      "name": "schemas",
      "path": "packages/schemas"
    },
    {
      "name": "services",
      "path": "packages/services"
    },
    {
      "name": "ui",
      "path": "packages/ui"
    },
    {
      "name": "utils",
      "path": "packages/utils"
    },
    {
      "name": "web",
      "path": "apps/web"
    },
    {
      "name": "workers",
      "path": "packages/workers"
    },
    {
      "name": "Developer Documentation",
      "path": "../dev-docs/arcagentic",
      "root": false
    },
    {
      "name": "GitHub Config",
      "path": ".github",
      "root": false
    }
  ],
  "extensions": {
    "recommendations": [
      "dbaeumer.vscode-eslint",
      "vitest.explorer",
      "ms-playwright.playwright",
      "bradlc.vscode-tailwindcss",
      "esbenp.prettier-vscode"
    ]
  },
  "settings": {
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit"
    },
    "eslint.workingDirectories": [
      {
        "directory": "packages/actors",
        "changeProcessCWD": true
      },
      {
        "directory": "packages/api",
        "changeProcessCWD": true
      },
      {
        "directory": "packages/bus",
        "changeProcessCWD": true
      },
      {
        "directory": "packages/characters",
        "changeProcessCWD": true
      },
      {
        "directory": "packages/db",
        "changeProcessCWD": true
      },
      {
        "directory": "packages/generator",
        "changeProcessCWD": true
      },
      {
        "directory": "packages/llm",
        "changeProcessCWD": true
      },
      {
        "directory": "packages/logger",
        "changeProcessCWD": true
      },
      {
        "directory": "packages/narrator",
        "changeProcessCWD": true
      },
      {
        "directory": "packages/projections",
        "changeProcessCWD": true
      },
      {
        "directory": "packages/retrieval",
        "changeProcessCWD": true
      },
      {
        "directory": "packages/schemas",
        "changeProcessCWD": true
      },
      {
        "directory": "packages/services",
        "changeProcessCWD": true
      },
      {
        "directory": "packages/ui",
        "changeProcessCWD": true
      },
      {
        "directory": "packages/utils",
        "changeProcessCWD": true
      },
      {
        "directory": "packages/workers",
        "changeProcessCWD": true
      },
      {
        "directory": "apps/web",
        "changeProcessCWD": true
      }
    ],
    "files.exclude": {
      "**/node_modules": true,
      "**/dist": true,
      "**/build": true,
      "**/coverage": true,
      "packages": true,
      "apps": true,
      ".github": true,
      ".vscode": true,
      ".pnpm-store": true,
      ".turbo": true,
    },
    "search.exclude": {
      "**/node_modules": true,
      "**/dist": true,
      "**/build": true,
      "**/coverage": true
    },
    "files.watcherExclude": {
      "**/node_modules/**": true,
      "**/dist/**": true,
      "**/build/**": true,
      "**/coverage/**": true
    },
    "editor.folding": false,
    "editor.foldingStrategy": "indentation",
    "[javascript]": {
      "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "[typescript]": {
      "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "[json]": {
      "editor.defaultFormatter": "vscode.json-language-features"
    },
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "editor.trimAutoWhitespace": true,
    "editor.renderWhitespace": "selection",
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "vitest.maximumConfigs": 20
  }
}
